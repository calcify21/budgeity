{
  "name": "budgeity",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:emu": "concurrently \"npm run emu\" \"npm run dev\" --kill-others",
    "emu": "node scripts/emu-start.cjs",
    "preview": "vite preview",
    "tran:check": "node scripts/i18n-check.cjs",
    "tran:clean": "node scripts/i18n-clean.cjs",
    "tran:sync": "node scripts/generate-i18n-types.cjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "build:f": "tsc && vite build --mode firebase",
    "build:h": "tsc && vite build --mode hostinger",
    "deploy": "npm run build:f && firebase deploy",
    "deploy:r": "npx firebase-tools deploy --only firestore:rules"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.19",
    "clsx": "^2.1.0",
    "driver.js": "^1.4.0",
    "firebase": "^12.12.0",
    "framer-motion": "^11.0.8",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.11",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.5.6",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.2",
    "tailwind-merge": "^2.2.1",
    "vite-plugin-pwa": "^1.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "firebase-admin": "^13.8.0",
    "globals": "^15.15.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^6.4.2"
  }
}